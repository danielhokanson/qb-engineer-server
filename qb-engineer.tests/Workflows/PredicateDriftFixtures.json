{
  "$schema": "Workflow Pattern Phase 4 — predicate evaluator drift fixtures.",
  "$description": "Each case is a (predicate, entity, expected) tuple. Both the TS evaluator (qb-engineer-ui/src/app/shared/services/predicate-drift-fixtures.spec.ts) and the C# evaluator (this folder's PredicateDriftFixtureTests) load the same JSON and assert their result matches expected. If both pass, the two implementations are in lock-step. Adding a case here REQUIRES both spec runs to verify before committing. KEEP IN SYNC with qb-engineer-ui/src/app/shared/services/__fixtures__/predicate-drift-fixtures.json.",
  "cases": [
    {
      "name": "fieldPresent_string_true",
      "predicate": { "type": "fieldPresent", "field": "name" },
      "entity": { "name": "Widget", "quantity": 5 },
      "expected": true
    },
    {
      "name": "fieldPresent_null_false",
      "predicate": { "type": "fieldPresent", "field": "name" },
      "entity": { "name": null, "quantity": 5 },
      "expected": false
    },
    {
      "name": "fieldPresent_whitespace_false",
      "predicate": { "type": "fieldPresent", "field": "name" },
      "entity": { "name": "   ", "quantity": 5 },
      "expected": false
    },
    {
      "name": "fieldEquals_string_match",
      "predicate": { "type": "fieldEquals", "field": "type", "value": "assembly" },
      "entity": { "type": "assembly", "name": "ASM-100" },
      "expected": true
    },
    {
      "name": "fieldEquals_bool_match",
      "predicate": { "type": "fieldEquals", "field": "isActive", "value": true },
      "entity": { "isActive": true },
      "expected": true
    },
    {
      "name": "fieldCompare_gt_true",
      "predicate": { "type": "fieldCompare", "field": "quantity", "op": "gt", "value": 5 },
      "entity": { "quantity": 10 },
      "expected": true
    },
    {
      "name": "fieldCompare_lte_boundary_true",
      "predicate": { "type": "fieldCompare", "field": "quantity", "op": "lte", "value": 5 },
      "entity": { "quantity": 5 },
      "expected": true
    },
    {
      "name": "fieldCompare_ne_true",
      "predicate": { "type": "fieldCompare", "field": "quantity", "op": "ne", "value": 7 },
      "entity": { "quantity": 5 },
      "expected": true
    },
    {
      "name": "relationExists_default_min_count_true",
      "predicate": { "type": "relationExists", "relation": "bomEntries" },
      "entity": { "bomEntries": [{ "id": 1 }] },
      "expected": true
    },
    {
      "name": "relationExists_empty_false",
      "predicate": { "type": "relationExists", "relation": "bomEntries" },
      "entity": { "bomEntries": [] },
      "expected": false
    },
    {
      "name": "relationExists_minCount_two_met",
      "predicate": { "type": "relationExists", "relation": "operations", "minCount": 2 },
      "entity": { "operations": [{ "id": 1 }, { "id": 2 }] },
      "expected": true
    },
    {
      "name": "relationCountCompare_eq_true",
      "predicate": { "type": "relationCountCompare", "relation": "tags", "op": "eq", "value": 3 },
      "entity": { "tags": ["a", "b", "c"] },
      "expected": true
    },
    {
      "name": "all_with_two_children_true",
      "predicate": {
        "type": "all",
        "of": [
          { "type": "fieldPresent", "field": "name" },
          { "type": "fieldCompare", "field": "quantity", "op": "gte", "value": 1 }
        ]
      },
      "entity": { "name": "X", "quantity": 5 },
      "expected": true
    },
    {
      "name": "any_one_branch_true",
      "predicate": {
        "type": "any",
        "of": [
          { "type": "fieldPresent", "field": "manualCostOverride" },
          { "type": "fieldPresent", "field": "currentCostCalculationId" }
        ]
      },
      "entity": { "manualCostOverride": 12.5 },
      "expected": true
    },
    {
      "name": "not_inverts_child",
      "predicate": { "type": "not", "of": { "type": "fieldPresent", "field": "name" } },
      "entity": { "name": "Widget" },
      "expected": false
    },
    {
      "name": "nested_all_inside_any_part_assembly_full",
      "predicate": {
        "type": "all",
        "of": [
          {
            "type": "all",
            "of": [
              { "type": "fieldPresent", "field": "name" },
              { "type": "fieldPresent", "field": "type" },
              { "type": "fieldPresent", "field": "material" }
            ]
          },
          { "type": "relationExists", "relation": "bomEntries", "minCount": 1 },
          { "type": "relationExists", "relation": "operations", "minCount": 1 },
          {
            "type": "any",
            "of": [
              { "type": "fieldPresent", "field": "manualCostOverride" },
              { "type": "fieldPresent", "field": "currentCostCalculationId" }
            ]
          }
        ]
      },
      "entity": {
        "name": "ASM-100",
        "type": "Assembly",
        "material": "Aluminum",
        "bomEntries": [{ "id": 1 }],
        "operations": [{ "id": 9 }],
        "manualCostOverride": 99.99
      },
      "expected": true
    },
    {
      "name": "unknown_type_false",
      "predicate": { "type": "madeUp", "field": "name" },
      "entity": { "name": "Widget" },
      "expected": false
    },
    {
      "name": "custom_unknown_ref_false",
      "predicate": { "type": "custom", "ref": "someComplexRule" },
      "entity": { "name": "Widget" },
      "expected": false
    }
  ]
}
